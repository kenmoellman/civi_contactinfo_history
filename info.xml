<?xml version="1.0"?>
<extension key="com.moellman.contactinfo_history" type="module">
  <file>contactinfo_history</file>
  <name>ContactInfo History</name>
  <description>Track and display historical changes to contact addresses, emails, and phone numbers using database triggers.</description>
  <license>AGPL-3.0</license>
  <maintainer>
    <author>Ken Moellman</author>
    <email>civicrm@mu-net.org</email>
  </maintainer>
  <urls>
    <url desc="Main Extension Page">https://github.com/kenmoellman/civi_contactinfo_history</url>
    <url desc="Documentation">https://github.com/kenmoellman/civi_contactinfo_history/blob/main/README.md</url>
    <url desc="Support">https://github.com/kenmoellman/civi_contactinfo_history/issues</url>
  </urls>
  <releaseDate>2026-03-25</releaseDate>
  <version>1.0.0</version>
  <develStage>stable</develStage>
  <compatibility>
    <ver>6.9</ver>
  </compatibility>
  <comments>Creates history tables for contact addresses, emails, and phone numbers, and provides a Contact History tab for viewing historical data.</comments>
  <civix>
    <namespace>CRM/ContactinfoHistory</namespace>
    <format>24.02.0</format>
  </civix>
</extension>
